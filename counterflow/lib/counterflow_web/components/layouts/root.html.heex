<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Counterflow">
      {assigns[:page_title]}
    </.live_title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js">
    </script>
    <script src="https://s3.tradingview.com/tv.js"></script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      // Three-way theme: "auto" (follows OS), "dark", "light".
      // Stored in localStorage.cf_theme; absence = auto. Auto removes the
      // data-theme attribute so prefers-color-scheme handles the swap.
      // Exposes window.cfSetTheme so onclick handlers on the toggle buttons
      // call this function directly — no LiveView round-trip needed.
      (() => {
        const KEY = "cf_theme";
        const apply = (mode) => {
          if (mode === "auto" || !mode) {
            document.documentElement.removeAttribute("data-theme");
          } else {
            document.documentElement.setAttribute("data-theme", mode);
          }
          document.querySelectorAll("[data-cf-theme]").forEach((b) => {
            b.classList.toggle("active", b.dataset.cfTheme === (mode || "auto"));
          });
        };

        window.cfSetTheme = (mode) => {
          if (mode === "auto") localStorage.removeItem(KEY);
          else localStorage.setItem(KEY, mode);
          apply(mode);
        };

        apply(localStorage.getItem(KEY) || "auto");

        window.addEventListener("storage", (e) => {
          if (e.key === KEY) apply(e.newValue || "auto");
        });

        // LiveView swaps DOM on page navigation; reapply active-class state.
        window.addEventListener("phx:page-loading-stop", () => {
          apply(localStorage.getItem(KEY) || "auto");
        });
      })();
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
