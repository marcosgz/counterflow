# Copy to .kamal/secrets and fill in real values. NEVER commit .kamal/secrets
# (already in .gitignore via the existing rules; verify before pushing).
#
# Generate SECRET_KEY_BASE with:
#   mix phx.gen.secret

# ── Required ──────────────────────────────────────────────
KAMAL_REGISTRY_USERNAME=marcosz
KAMAL_REGISTRY_PASSWORD=<docker-hub-pat-or-password>

SECRET_KEY_BASE=<run mix phx.gen.secret on dev>
POSTGRES_PASSWORD=<a-strong-random-string>

# DATABASE_URL points the app at the accessory DB on the same host.
# Use the postgres user/pw above; counterflow_prod is the DB name from deploy.yml.
DATABASE_URL=ecto://counterflow:<POSTGRES_PASSWORD>@host.docker.internal:5432/counterflow_prod

# First-boot owner (auto-creates if no users exist)
COUNTERFLOW_OWNER_EMAIL=you@example.com
COUNTERFLOW_OWNER_PASSWORD=<at-least-8-chars>

# ── Optional ──────────────────────────────────────────────
# Telegram alerts
COUNTERFLOW_TELEGRAM_BOT_TOKEN=
COUNTERFLOW_TELEGRAM_CHAT_ID=

# Weekly LLM digest (anthropic | openai)
COUNTERFLOW_LLM_PROVIDER=anthropic
COUNTERFLOW_LLM_API_KEY=
COUNTERFLOW_LLM_MODEL=claude-sonnet-4-6

# Binance — only for Phase 8a (testnet) / 8b (live) activation
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Override deploy target if pointing somewhere other than the production host
DEPLOY_HOST=counterflow.marcosz.com.br
